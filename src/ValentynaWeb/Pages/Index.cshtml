@page
@model IndexModel
@{
    ViewData["Title"] = "Валентина — перукарня";
}

<header class="hero-background" id="home">
  <!-- Хедер -->
  <div class="header">
    <div class="logo-container">
      <p class="logo"><span data-translate="logo-main">ВАЛЕНТИНА</span> <span class="logo-span" data-translate="logo-sub">перукарня</span></p>
      <div class="mobile-language-switch">
        <button class="lang-btn active" data-lang="ua">UA</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
      <button type="button" class="menu-burger" id="burger-btn">
        <svg class="menu-burger-icon">
          <use href="#menu-burger"></use>
        </svg>
      </button>

      <div class="mobile-menu" id="mobile-menu">
        <button type="button" class="close-button" id="close-btn">
          <svg class="menu-close-icon">
            <use href="#menu-close"></use>
          </svg>
        </button>
        <div class="mobile-menu-container">
          <p class="logo-mobile">
            <span data-translate="logo-main">ВАЛЕНТИНА</span> <span class="logo-span" data-translate="logo-sub">перукарня</span>
          </p>
          <nav class="mobile-nav">
            <ul class="mobile-nav-list">
              <li><a href="#home" class="mobile-nav-link" data-translate="nav-home">Головна</a></li>
              <li><a href="#services" class="mobile-nav-link" data-translate="nav-services">Послуги</a></li>
              <li><a href="#about" class="mobile-nav-link" data-translate="nav-about">Про нас</a></li>
              <li><a href="#price" class="mobile-nav-link" data-translate="nav-price">Прайс</a></li>
              <li><a href="#gallery" class="mobile-nav-link" data-translate="nav-gallery">Галерея</a></li>
              <li><a href="#booking" class="mobile-nav-link" data-translate="nav-contacts">Контакти</a></li>
            </ul>
          </nav>
          <a href="@Model.BookingUrl" class="mobile-book-btn" data-translate="hero-book">Записатися</a>
          <div class="mobile-contacts">
            <div class="mobile-contacts-img">
              <svg class="mobile-phone-icon">
                <use href="#phone-modal"></use>
              </svg>
            </div>
            <a href="tel:+380989985522" class="mobile-phone">+38 (098) 998-55-22</a>
          </div>
          <div class="footer-link-container">
            <div class="footer-link-img-container">
              <a href="https://facebook.com" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#facebook"></use></svg>
              </a>
            </div>
            <div class="footer-link-img-container">
              <a href="https://www.youtube.com" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#youtube"></use></svg>
              </a>
            </div>
            <div class="footer-link-img-container">
              <a href="https://www.instagram.com/valentyna_perukarnia/" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#instagram"></use></svg>
              </a>
            </div>
            <div class="footer-link-img-container">
              <a href="https://web.telegram.org" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#telegram2"></use></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="nav-container">
      <div class="nav-container-inner">
        <nav class="nav">
          <ul class="nav-list">
            <li><a href="#home" class="nav-link" data-translate="nav-home">Головна</a></li>
            <li><a href="#about" class="nav-link" data-translate="nav-about">Про нас</a></li>
            <li><a href="#price" class="nav-link" data-translate="nav-price">Прайс</a></li>
            <li><a href="#gallery" class="nav-link" data-translate="nav-gallery">Галерея</a></li>
            <li><a href="#booking" class="nav-link" data-translate="nav-contacts">Контакти</a></li>
