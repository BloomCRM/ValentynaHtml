@page
@model IndexModel
@{
    ViewData["Title"] = "Валентина — перукарня";
}

<header class="hero-background" id="home">
  <!-- Хедер -->
  <div class="header">
    <div class="logo-container">
      <p class="logo"><span data-translate="logo-main">ВАЛЕНТИНА</span> <span class="logo-span" data-translate="logo-sub">перукарня</span></p>
      <div class="mobile-language-switch">
        <button class="lang-btn active" data-lang="ua">UA</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
      <button type="button" class="menu-burger" id="burger-btn">
        <svg class="menu-burger-icon">
          <use href="#menu-burger"></use>
        </svg>
      </button>

      <div class="mobile-menu" id="mobile-menu">
        <button type="button" class="close-button" id="close-btn">
          <svg class="menu-close-icon">
            <use href="#menu-close"></use>
          </svg>
        </button>
        <div class="mobile-menu-container">
          <p class="logo-mobile">
            <span data-translate="logo-main">ВАЛЕНТИНА</span> <span class="logo-span" data-translate="logo-sub">перукарня</span>
          </p>
          <nav class="mobile-nav">
            <ul class="mobile-nav-list">
              <li><a href="#home" class="mobile-nav-link" data-translate="nav-home">Головна</a></li>
              <li><a href="#services" class="mobile-nav-link" data-translate="nav-services">Послуги</a></li>
              <li><a href="#about" class="mobile-nav-link" data-translate="nav-about">Про нас</a></li>
              <li><a href="#price" class="mobile-nav-link" data-translate="nav-price">Прайс</a></li>
              <li><a href="#gallery" class="mobile-nav-link" data-translate="nav-gallery">Галерея</a></li>
              <li><a href="#booking" class="mobile-nav-link" data-translate="nav-contacts">Контакти</a></li>
            </ul>
          </nav>
          <a href="@Model.BookingUrl" class="mobile-book-btn" data-translate="hero-book">Записатися</a>
          <div class="mobile-contacts">
            <div class="mobile-contacts-img">
              <svg class="mobile-phone-icon">
                <use href="#phone-modal"></use>
              </svg>
            </div>
            <a href="tel:+380989985522" class="mobile-phone">+38 (098) 998-55-22</a>
          </div>
          <div class="footer-link-container">
            <div class="footer-link-img-container">
              <a href="https://facebook.com" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#facebook"></use></svg>
              </a>
            </div>
            <div class="footer-link-img-container">
              <a href="https://www.youtube.com" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#youtube"></use></svg>
              </a>
            </div>
            <div class="footer-link-img-container">
              <a href="https://www.instagram.com/valentyna_perukarnia/" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#instagram"></use></svg>
              </a>
            </div>
            <div class="footer-link-img-container">
              <a href="https://web.telegram.org" target="_blank" class="footer-svg-link">
                <svg class="footer-link-icon"><use href="#telegram2"></use></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="nav-container">
      <div class="nav-container-inner">
        <nav class="nav">
          <ul class="nav-list">
            <li><a href="#home" class="nav-link" data-translate="nav-home">Головна</a></li>
            <li><a href="#about" class="nav-link" data-translate="nav-about">Про нас</a></li>
            <li><a href="#price" class="nav-link" data-translate="nav-price">Прайс</a></li>
            <li><a href="#gallery" class="nav-link" data-translate="nav-gallery">Галерея</a></li>
            <li><a href="#booking" class="nav-link" data-translate="nav-contacts">Контакти</a></li>
          </ul>
        </nav>
      </div>
      <div class="nav-actions">
        <div class="language-switch">
          <button class="lang-btn active" data-lang="ua">UA</button>
          <button class="lang-btn" data-lang="en">EN</button>
        </div>
        <a href="https://t.me/valentyna_perukarnia" target="_blank" rel="noopener noreferrer" class="nav-button">
          <span data-translate="telegram-btn">написати в Telegram</span>
          <svg class="icon"><use href="#telegram"></use></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Херо -->
  <section class="hero">
    <div class="hero-content container">
      <h1 class="hero-title" data-translate="hero-title">Час бути собою</h1>
      <div class="hero-buttons">
        <a href="@Model.BookingUrl" target="_blank" class="first-button" data-translate="hero-book">Записатися</a>
        <a href="#services" class="second-button" data-translate="hero-services">Перейти до послуг</a>
      </div>
    </div>
  </section>
</header>

<section class="services" id="services">
  <h2 class="services-title" data-translate="services-title">ПОСЛУГИ</h2>
  <ul class="services-lisl">
    <li class="services-item">
      <responsive-img src="img/cuts" alt="Стрижки" sizes="(max-width:767px) 100vw, 20vw" />
      <p class="services-text" data-translate="services-cuts">СТРИЖКИ</p>
    </li>
    <li class="services-item">
      <responsive-img src="img/ukladka2" alt="Укладки" sizes="(max-width:767px) 100vw, 20vw" />
      <p class="services-text" data-translate="services-styling">УКЛАДКИ</p>
    </li>
    <li class="services-item">
      <responsive-img src="img/doglyad2" alt="Догляд" sizes="(max-width:767px) 100vw, 20vw" />
      <p class="services-text" data-translate="services-care">ДОГЛЯД</p>
    </li>
    <li class="services-item">
      <picture>
        <source media="(max-width: 767px)" srcset="~/img/tas.png 1x, ~/img/tas.png 2x" />
        <img src="~/img/tas.png" alt="ПРОЦЕДУРИ" loading="lazy" />
      </picture>
      <p class="services-text" data-translate="services-chemical">ХІМ ТА БІО ЗАВИВКА</p>
    </li>
    <li class="services-item">
      <responsive-img src="img/doglyad" alt="Фарбування" sizes="(max-width:767px) 100vw, 20vw" />
      <p class="services-text" data-translate="services-coloring">ФАРБУВАННЯ</p>
    </li>
  </ul>
  <a href="@Model.BookingUrl" target="_blank" class="services-btn" data-translate="hero-book">Записатися</a>
</section>

<section class="about" id="about">
  <h2 class="about-title" data-translate="about-title">ПРО НАС</h2>
  <div class="about-container">
    <p class="about-logo">
      <span data-translate="logo-main">ВАЛЕНТИНА</span> <span class="about-logo-span" data-translate="logo-sub">перукарня</span>
    </p>
    <div class="about-text-container">
      <p class="about-text about-text-desktop" data-translate="about-text-desktop">
        Я створив місце, де зібрав усе, що люблю і вмію. Хочу зробити
        найкращу перукарню в Києві, і вкладаю в цей проєкт 101% себе. Це
        місце, де можна стати щасливішим. За годину (а з фарбуванням і за
        4-7 годин) можна змінити не просто зачіску, а настрій людини. У нас
        класна музика, затишна атмосфера, смачна кава – все, щоб ти
        почувався комфортно. Люблю динамічні стрижки та експерименти. Мій
        досвід дозволяє створювати форму, яка природно виглядає та гарно
        відростає. Волосся – це не просто стрижка, а частина образу, яка
        потребує уваги. Тому догляд, стайлінг і сушка феном – must-have, щоб
        розкрити його потенціал.
      </p>
      <p class="about-text about-text-mobile" data-translate="about-text-mobile">
        Я створив місце, де зібрав усе, що люблю і вмію. Хочу зробити
        найкращу перукарню в Києві, і вкладаю в цей проєкт 101% себе. Це
        місце, де можна стати щасливішим. За годину (а з фарбуванням і за
        4-7 годин) можна змінити не просто зачіску, а настрій людини. У нас
        класна музика, затишна атмосфера, смачна кава – все, щоб ти
        почувався комфортно. Люблю динамічні стрижки та експерименти. Мій
        досвід дозволяє створювати форму, яка природно виглядає та гарно
        відростає.
      </p>
      <div class="about-author">
        <img src="~/img/avatar.png" alt="Фото Валентина" class="author-avatar" />
        <div class="about-author-info">
          <p class="author-name" data-translate="author-name">Валентин Галицький</p>
          <p class="author-role" data-translate="author-role">Засновник Перукарні Валентина</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cosmetics">
  <div class="cosmetics-container">
    <div class="cosmetics-text">
      <h2 class="cosmetics-title" data-translate="cosmetics-title">Косметика, яку ми використовуємо</h2>
      <p class="cosmetics-description" data-translate="cosmetics-description">
        Засоби для догляду за волоссям пропонують індивідуальну систему
        догляду, створену спеціально для вас. Використовуючи натуральні
        інгредієнти, науково доведено, що ця преміальна лінія забезпечує
        найкращий догляд за вашим волоссям. ми надаємо професійні
        рекомендації щодо догляду за волоссям, допомагаючи вам обрати
        ідеальні засоби, які відповідають вашому типу та стилю волосся
      </p>
    </div>
    <responsive-img src="img/cosmetics" alt="cosmetics" img-class="cosmetics-image" sizes="(max-width:767px) 100vw, 50vw" />
  </div>
</section>

<section class="gallery" id="gallery">
  <h2 class="gallery-title" data-translate="gallery-title">ГАЛЕРЕЯ РОБІТ</h2>
  <div class="gallery-container">
    <div class="gallery-desktop">
      <div class="gallery-slider">
        <button class="gallery-nav-btn gallery-prev" aria-label="Previous">&#8249;</button>
        <div class="gallery-scroll-container">
          <div class="gallery-slide active">
            <img src="~/img/gallery 11.jpg" alt="gallery" class="gallery-desktop-image" />
            <img src="~/img/gallery 2.jpg" alt="gallery" class="gallery-desktop-image" />
            <responsive-img src="img/gallery 3" alt="gallery" img-class="gallery-desktop-image" sizes="(max-width:767px) 50vw, 25vw" />
            <img src="~/img/gallery 4.jpg" alt="gallery" class="gallery-desktop-image" />
          </div>
          <div class="gallery-slide">
            <img src="~/img/gallery 5.png" alt="gallery" class="gallery-desktop-image" />
            <img src="~/img/gallery 6.png" alt="gallery" class="gallery-desktop-image" />
            <img src="~/img/gallery 7.jpg" alt="gallery" class="gallery-desktop-image" />
            <responsive-img src="img/gallery 8" alt="gallery" img-class="gallery-desktop-image" sizes="(max-width:767px) 50vw, 25vw" />
          </div>
        </div>
        <button class="gallery-nav-btn gallery-next" aria-label="Next">&#8250;</button>
      </div>
      <div class="gallery-indicators">
        <button class="gallery-indicator active" data-slide="0"></button>
        <button class="gallery-indicator" data-slide="1"></button>
      </div>
    </div>

    <a href="https://www.instagram.com/valentyna_perukarnia/" class="gallery-link" target="_blank" rel="noopener noreferrer">
      <span data-translate="gallery-more">More photos in Instagram</span>
      <svg class="gallery-icon"><use href="#instagram"></use></svg>
    </a>

    <div class="gallery-mobile">
      <div class="gallery-mobile-scroll-container">
        <img src="~/img/gallery 11.jpg" alt="gallery" class="gallery-mobile-image" />
        <img src="~/img/gallery 2.jpg" alt="gallery" class="gallery-mobile-image" />
        <responsive-img src="img/gallery 3" alt="gallery" img-class="gallery-mobile-image" sizes="50vw" />
        <img src="~/img/gallery 4.jpg" alt="gallery" class="gallery-mobile-image" />
        <img src="~/img/gallery 5.png" alt="gallery" class="gallery-mobile-image" />
        <img src="~/img/gallery 6.png" alt="gallery" class="gallery-mobile-image" />
        <img src="~/img/gallery 7.jpg" alt="gallery" class="gallery-mobile-image" />
        <responsive-img src="img/gallery 8" alt="gallery" img-class="gallery-mobile-image" sizes="50vw" />
      </div>
    </div>
  </div>

  <div class="lightbox-modal" id="lightbox-modal">
    <div class="lightbox-content">
      <button class="lightbox-close" id="lightbox-close">&times;</button>
      <img class="lightbox-image" id="lightbox-image" src="" alt="Gallery image" />
      <button class="lightbox-nav lightbox-prev" id="lightbox-prev">&#8249;</button>
      <button class="lightbox-nav lightbox-next" id="lightbox-next">&#8250;</button>
    </div>
  </div>
</section>

<section class="price" id="price">
  <div class="price-container">
    <h2 class="price-title" data-translate="price-title">ПОСЛУГИ ТА ЦІНИ</h2>
    <p class="price-description" data-translate="price-description">
      Ми Перукарня Валентина. Інклюзивна перукарня, де є місце для кожного. Місцева перукарня, що робить стиль без меж.
    </p>
    <div class="price-cards">
      @foreach (var category in Model.ServiceCategories)
      {
        <div class="@category.CssClass">
          <div class="price-item-title-container">
            <svg class="price-icon"><use href="#price-item-icon" class="price-icon-svg"></use></svg>
            <p class="price-item-title">@category.Name</p>
          </div>
          <ul class="price-list">
            @foreach (var service in category.Services)
            {
              <li class="@category.RowCssClass">
                @if (service.IsGroupHeader)
                {
                  <p class="service-name-group">@service.Name</p>
                }
                else
                {
                  <span class="service-name">@service.Name</span>
                  <span class="service-price">@service.PriceDisplay</span>
                }
              </li>
            }
          </ul>
        </div>
      }
    </div>
    <a href="@Model.BookingUrl" target="_blank" class="price-button" data-translate="hero-book">Записатися</a>
  </div>
</section>

<section class="news">
  <div class="news-container">
    <h2 class="news-title" data-translate="news-title">ПОДІЇ ТА НОВИТИ У ПЕРУКАРНІ ВАЛЕНТИНА</h2>
    <p class="news-subtitle" data-translate="news-subtitle">
      Завітайте до нас на цікаві події та користуйтесь акційними пропозиціями
    </p>
    <div class="news-scroll-container">
      <div class="news-card">
        <div class="news-img-1"></div>
        <h2 class="news-card-title" data-translate="news-music">МУЗИЧНИЙ ВЕЧІР</h2>
        <p class="news-card-description" data-translate="news-music-desc">
          9 березня о 18:00 у перукарні «Валентина» відбудеться затишний
          музичний вечір. За інструментом – талановитий Міша Качур.
          Приходьте насолодитися живою музикою та приємною атмосферою!
        </p>
        <button type="button" class="news-button" data-translate="news-details">Детальніше»</button>
        <div class="card-line"></div>
        <p class="date" data-translate="news-date-1">8 березня 2025</p>
      </div>
      <div class="news-card">
        <div class="news-img-2"></div>
        <h2 class="news-card-title" data-translate="news-valentine">ДЕНЬ ЗАКОХАНИХ У ВАЛЕНТИНІ</h2>
        <p class="news-card-description" data-translate="news-valentine-desc">
          Запрошуємо вас 14 лютого на святкування Дня Закоханих у перукарні
          «Валентина»! На вас чекають смачні мочі, гарячий рамен і музична
          атмосфера від DJ Emergencyloop. 30% прибутку буде передано на
